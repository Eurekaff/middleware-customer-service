# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./app.db

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_TASK_QUEUE=customer_service:task_queue
REDIS_KEY_PREFIX=customer_service

# MCP
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=9000

# LLM, optional OpenAI-compatible API.
# Default provider is Alibaba Cloud Model Studio / DashScope in OpenAI-compatible mode.
# Leave LLM_ENABLE=false for fully local rule/template fallback mode.
LLM_ENABLE=false
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=20

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000/api
